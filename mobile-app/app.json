{
  "expo": {
    "name": "TripGenie",
    "slug": "tripgenie",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devanshsadhotra.tripgenie"
    },
    "android": {
      "package": "com.devanshsadhotra.tripgenie",
      "adaptiveIcon": {
        "backgroundColor": "#F4EFE7"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
